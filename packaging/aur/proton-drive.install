post_install() {
  update-desktop-database -q /usr/share/applications
  gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor
  echo "NOTE: WebKitGTK sandbox is disabled in this build for compatibility."
  echo "See https://github.com/DonnieDice/protondrive-linux for details."
}

post_upgrade() {
  post_install
}

post_remove() {
  update-desktop-database -q /usr/share/applications
  gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor
}
