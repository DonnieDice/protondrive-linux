{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proton Drive",
  "version": "1.4.4",
  "identifier": "com.proton.drive",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../WebClients/applications/drive/dist"
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/proton-drive.svg"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "DonnieDice",
    "category": "Utility",
    "shortDescription": "Encrypted cloud storage",
    "longDescription": "Proton Drive is encrypted cloud storage that protects your files with end-to-end encryption.",
    "license": "AGPL-3.0",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: asset: https: blob: data:; connect-src ipc: https: blob: data: 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data: https:; worker-src 'self' blob:; media-src 'self' blob: https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true,
    "windows": []
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
